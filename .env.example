# Environment variables for SHL Assessment Recommender
# Copy this to .env and fill in your API key(s)

# At least ONE of these is required for LLM-powered conversations
# Get free Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative: Groq (free tier) at https://console.groq.com
GROQ_API_KEY=

# Alternative: OpenRouter (free tier) at https://openrouter.ai/keys
# Defaults to the "Free Models Router" (openrouter/free); override with
# OPENROUTER_MODEL to pin a specific :free model instead.
OPENROUTER_API_KEY=

# Server port (default 8000)
PORT=8000
